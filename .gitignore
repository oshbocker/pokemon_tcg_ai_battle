# Generated outputs — caches, replays, leaderboards, logs, checkpoints, run dirs.
# Ignore the WHOLE tree: training run dirs (e.g. probe_*/, what download_artifacts.py
# pulls from Drive) land here and must stay local — checkpoints are large. Keep only the
# placeholder and the small, already-committed orbit-wars discussion extracts.
outputs/*
!outputs/.gitkeep
!outputs/orbit_wars_discussions/

# Built submission bundles (rebuild from source)
submissions/
*.tar.gz

# Competition data files (card metadata PDFs/CSVs — re-download via the API)
data/

# Python
__pycache__/
*.py[cod]
*.so
# ...but the cabt Linux engine must be tracked so Colab clones can run it
# (the Windows cg.dll is already tracked; keep the Linux .so alongside it)
!agent/cg/libcg.so
*.egg-info/
dist/
build/
.env
.venv/
venv/

# Jupyter
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# Kaggle credentials — never commit
kaggle.json

# Local Claude Code settings (keep shared skills versioned)
.claude/*
!.claude/skills/

# Tooling caches
.ruff_cache/
.pyright/
